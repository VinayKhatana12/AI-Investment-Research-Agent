{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "set NODE_OPTIONS=--max-old-space-size=4096 && ..\\node_modules\\.bin\\tsc.cmd",
    "typecheck": "set NODE_OPTIONS=--max-old-space-size=4096 && ..\\node_modules\\.bin\\tsc.cmd --noEmit",
    "test:tools": "tsx src/scripts/test-tools.ts",
    "test:agent": "tsx src/scripts/test-agent.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/google-genai": "^0.2.0",
    "@langchain/langgraph": "^0.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "@tavily/core": "^0.7.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
