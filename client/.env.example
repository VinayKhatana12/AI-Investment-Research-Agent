# Client environment variables — Vite
# Copy this file to .env.local for local development (it will be gitignored).
# In Vercel: add these as Environment Variables in the project dashboard.

# Leave empty in local dev — Vite proxy rewrites /api → http://localhost:3001
# In production: set to your deployed backend URL (no trailing slash)
# Example: https://ai-investment-agent.onrender.com
VITE_API_URL=
